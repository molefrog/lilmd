{
  "name": "mdq",
  "version": "0.0.0",
  "description": "CLI for working with large MD files — Markdown is the new DB",
  "type": "module",
  "private": true,
  "bin": {
    "mdq": "./dist/mdq.js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bunup",
    "build:watch": "bunup --watch",
    "test": "bun test ./src",
    "typecheck": "tsc --noEmit",
    "bench:parse": "bun dev/bench/parse.ts",
    "bench:query": "bun dev/bench/query.ts",
    "bench:cli": "bun dev/bench/cli.ts",
    "bench:positions": "bun dev/bench/positions.ts",
    "fixtures": "bun dev/make-fixtures.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/markdown-it": "^14.1.2",
    "bunup": "^0.16.31",
    "cac": "^7.0.0",
    "citty": "^0.2.2",
    "markdown-it": "^14.1.1",
    "marked": "^18.0.0",
    "md4w": "^0.2.7",
    "mdast-util-from-markdown": "^2.0.3",
    "micromark": "^4.0.2",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
